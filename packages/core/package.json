{
  "name": "@signal-kernel/core",
  "version": "0.1.1",
  "type": "module",
  "author": "Luciano Lee",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Luciano0322/signal-kernel.git"
  },
  "homepage": "https://github.com/Luciano0322/signal-kernel#readme",
  "bugs": {
    "url": "https://github.com/Luciano0322/signal-kernel/issues"
  },
  "keywords": [
    "signals",
    "reactivity",
    "fine-grained",
    "reactive",
    "state-management",
    "runtime",
    "scheduler"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.dts.json",
    "lint": "pnpm exec eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
